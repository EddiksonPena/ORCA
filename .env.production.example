MEMORY_API_PORT=4000
WORKER_PORT=4010
ORCA_PROXY_PORT=4030
REDIS_URL=redis://working-memory-cache:6379
MEMORY_STATE_BACKEND=redis
MEMORY_STATE_REDIS_KEY=orca:state:v1
WEAVIATE_HTTP_URL=http://semantic-vector-store:8080
NEO4J_URI=bolt://knowledge-graph-store:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=replace-me
TEMPORAL_ADDRESS=temporal-service:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_WORKFLOW_TASK_QUEUE=orca-memory-module
TEMPORAL_EXECUTION_MODE=temporal
TEMPORAL_GRAPH_BACKEND=neo4j-temporal
OTEL_EXPORTER_OTLP_ENDPOINT=http://telemetry-collector:4318
EMBEDDING_PROVIDER=transformers
EMBEDDING_MODEL=onnx-community/Qwen3-Embedding-0.6B-ONNX
EMBEDDING_DTYPE=q8
EMBEDDING_DIMENSIONS=1024
EMBEDDING_QUERY_INSTRUCTION=Given an agent memory recall query, retrieve relevant memories that answer or contextualize the query
EMBEDDING_CACHE_DIR=/app/data/models/transformers
RERANKER_MODEL=bge-reranker-base
EXTRACTION_MODEL=qwen2.5:14b
GRAPHITI_EMBEDDING_MODEL=nomic-embed-text
MAX_REQUEST_BYTES=1048576
SHUTDOWN_TIMEOUT_MS=10000
ORCA_API_KEY=replace-me
ORCA_AUTH_MODE=hybrid
ORCA_JWT_ISSUER=https://issuer.example.com/
ORCA_JWT_AUDIENCE=orca-api
ORCA_JWKS_URL=
ORCA_JWT_REQUIRED_SCOPES=orca.read,orca.write
ORCA_BASE_URL=https://orca-api.example.com
ORCA_DEFAULT_SCOPE=workspace
ORCA_REQUIRED=true
ORCA_FAILURE_MODE=block
OPENAI_BASE_URL=https://api.openai.com
ORCA_PROXY_UPSTREAM_BASE_URL=https://api.openai.com
ORCA_PROXY_MAX_REQUEST_BYTES=1048576
ORCA_PROXY_MEMORY_BLOCK_MAX_CHARS=6000
OPENAI_API_KEY=replace-me
MEMORY_DATA_DIR=/app/data
MEMORY_DATA_FILE=/app/data/orca-memory-os.json
APP_REDIS_URL=redis://working-memory-cache:6379
APP_WEAVIATE_HTTP_URL=http://semantic-vector-store:8080
APP_NEO4J_URI=bolt://knowledge-graph-store:7687
APP_NEO4J_USERNAME=neo4j
APP_NEO4J_PASSWORD=replace-me
APP_TEMPORAL_ADDRESS=temporal-service:7233
APP_TEMPORAL_NAMESPACE=default
APP_TEMPORAL_WORKFLOW_TASK_QUEUE=orca-memory-module
APP_OTEL_EXPORTER_OTLP_ENDPOINT=http://telemetry-collector:4318
